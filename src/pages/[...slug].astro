---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonical = `https://blog.getstudyedge.com/${post.id}/`;
const dateLabel = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: canonical,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: 'StudyEdge AI' },
  publisher: {
    '@type': 'Organization',
    name: 'StudyEdge AI',
    url: 'https://getstudyedge.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://getstudyedge.com/favicon.png',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  articleSection: post.data.tag,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://getstudyedge.com' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://blog.getstudyedge.com' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
  ],
};
---
<BaseLayout
  title={`${post.data.title} | StudyEdge AI Blog`}
  description={post.data.description}
  canonical={canonical}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tag={post.data.tag}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="px-6 pt-16 pb-8">
    <div class="max-w-prose mx-auto">
      <div class="text-[12px] uppercase tracking-wider text-accent font-bold mb-4">
        <a href="/" class="hover:underline">Blog</a>
        <span class="text-dim"> &middot; </span>
        <span>{post.data.tag}</span>
        <span class="text-dim"> &middot; </span>
        <span class="text-muted normal-case tracking-normal font-normal">{dateLabel} &middot; {post.data.minutes} min read</span>
      </div>

      <div class="prose">
        <h1>{post.data.title}</h1>
      </div>

      <p class="text-[19px] leading-relaxed text-muted mt-4 mb-10">{post.data.description}</p>
    </div>
  </article>

  <article class="px-6 pb-16">
    <div class="max-w-prose mx-auto prose">
      <Content />
    </div>
    <div class="max-w-prose mx-auto">
      <CTA />
    </div>
  </article>
</BaseLayout>
