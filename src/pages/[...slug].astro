---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import TagBadge from '../components/TagBadge.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const canonical = `https://blog.getstudyedge.com/${post.id}/`;
const dateLabel = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: canonical,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: { '@type': 'Organization', name: 'StudyEdge AI' },
  publisher: {
    '@type': 'Organization',
    name: 'StudyEdge AI',
    url: 'https://getstudyedge.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://blog.getstudyedge.com/favicon.png',
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  articleSection: post.data.tag,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://getstudyedge.com' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://blog.getstudyedge.com' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
  ],
};
---
<BaseLayout
  title={`${post.data.title} | StudyEdge AI Blog`}
  description={post.data.description}
  canonical={canonical}
  type="article"
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tag={post.data.tag}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <article class="px-6 pt-14 pb-6">
    <div class="max-w-[720px] mx-auto">
      <nav class="flex items-center gap-2 text-[12.5px] text-muted mb-7" aria-label="Breadcrumb">
        <a href="/" class="hover:text-text no-underline hover:no-underline">Blog</a>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" class="text-dim">
          <path d="M3.5 2L6.5 5L3.5 8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <TagBadge tag={post.data.tag} size="sm" />
      </nav>

      <div class="prose">
        <h1>{post.data.title}</h1>
      </div>

      <p class="text-[20px] leading-[1.55] text-muted mt-5 mb-8 font-normal">
        {post.data.description}
      </p>

      <div class="flex items-center gap-3 text-[13px] text-muted pb-2">
        <div class="flex items-center gap-2">
          <img src="/icon-128.png" alt="StudyEdge AI" width="32" height="32" class="w-8 h-8 rounded-lg" />
          <span class="font-semibold text-text">StudyEdge AI</span>
        </div>
        <span class="w-1 h-1 rounded-full bg-dim"></span>
        <time datetime={post.data.pubDate.toISOString()}>{dateLabel}</time>
        <span class="w-1 h-1 rounded-full bg-dim"></span>
        <span>{post.data.minutes} min read</span>
      </div>
    </div>
  </article>

  <article class="px-6 pb-16">
    <div class="max-w-[720px] mx-auto prose">
      <Content />
    </div>
    <div class="max-w-[720px] mx-auto">
      <CTA />
      <RelatedPosts currentSlug={post.id} />
    </div>
  </article>
</BaseLayout>
