---
interface Props {
  tag: string;
  size?: 'sm' | 'md';
  href?: string;
}
const { tag, size = 'md', href } = Astro.props;

const styles: Record<string, string> = {
  'GPA':              'bg-emerald-50 text-emerald-700 ring-emerald-600/15',
  'Exam Prep':        'bg-amber-50 text-amber-800 ring-amber-600/20',
  'Study Techniques': 'bg-indigo-50 text-indigo-700 ring-indigo-600/15',
  'Planning':         'bg-rose-50 text-rose-700 ring-rose-600/15',
  'Focus':            'bg-sky-50 text-sky-700 ring-sky-600/15',
  'Mental Health':    'bg-violet-50 text-violet-700 ring-violet-600/15',
};
const colorCls = styles[tag] ?? 'bg-stone-100 text-stone-700 ring-stone-600/10';
const sizeCls = size === 'sm'
  ? 'text-[10.5px] px-2 py-[3px]'
  : 'text-[11px] px-2.5 py-1';
const baseCls = `inline-flex items-center font-semibold tracking-wide uppercase rounded-full ring-1 ring-inset ${colorCls} ${sizeCls}`;
---
{href ? (
  <a href={href} class={`${baseCls} no-underline hover:no-underline hover:brightness-95 transition`}>{tag}</a>
) : (
  <span class={baseCls}>{tag}</span>
)}
