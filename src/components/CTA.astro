---
interface Props {
  heading?: string;
  body?: string;
  buttonLabel?: string;
}
const {
  heading = 'Put the system to work',
  body = 'StudyEdge AI is the study planner that knows your courses, your grade weights, and your exam dates. Free to start.',
  buttonLabel = 'Try StudyEdge AI Free',
} = Astro.props;
const appUrl = 'https://getstudyedge.com/app?signup=1&plan=pro&billing=monthly&trial=1';
---
<section class="my-12 bg-card border border-border rounded-2xl p-8 text-center shadow-[0_1px_3px_rgba(0,0,0,0.04)]">
  <h3 class="text-[22px] font-bold text-text mb-2">{heading}</h3>
  <p class="text-muted text-[16px] max-w-xl mx-auto mb-5">{body}</p>
  <a href={appUrl} class="inline-flex items-center gap-2 bg-accent hover:bg-accentDark text-white font-semibold text-[15px] px-6 py-3 rounded-lg no-underline hover:no-underline transition-colors">
    {buttonLabel}
  </a>
  <p class="text-xs text-dim mt-3">Free to start. No credit card required.</p>
</section>
