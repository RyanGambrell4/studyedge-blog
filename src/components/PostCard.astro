---
import TagBadge from './TagBadge.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tag: string;
  minutes: number;
}
const { href, title, description, pubDate, tag, minutes } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<a
  href={href}
  class="relative block group bg-card border border-border rounded-2xl p-7 shadow-[0_1px_2px_rgba(15,15,15,0.04)] hover:shadow-[0_14px_40px_-12px_rgba(15,15,15,0.18)] hover:-translate-y-1 hover:border-black/[0.12] transition-all duration-300 ease-out no-underline hover:no-underline"
>
  <div class="mb-4">
    <TagBadge tag={tag} size="md" />
  </div>
  <h2 class="text-[22px] font-bold leading-[1.25] tracking-tight text-text mb-2 group-hover:text-accent transition-colors">
    {title}
  </h2>
  <p class="text-muted text-[15px] leading-relaxed mb-5">{description}</p>
  <div class="flex items-center justify-between text-[12.5px] text-dim">
    <span>{dateLabel} &middot; {minutes} min read</span>
    <span class="text-accent font-semibold inline-flex items-center gap-1 group-hover:gap-2 transition-all">
      Read article
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M3 7h8m0 0L7.5 3.5M11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>
