---
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  tag: string;
  minutes: number;
}
const { href, title, description, pubDate, tag, minutes } = Astro.props;
const dateLabel = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<a href={href} class="block group bg-card border border-border rounded-2xl p-6 shadow-[0_1px_3px_rgba(0,0,0,0.04)] hover:shadow-[0_8px_24px_rgba(0,0,0,0.07)] transition-shadow no-underline hover:no-underline">
  <div class="inline-flex items-center gap-1 text-[11px] font-semibold tracking-wide uppercase text-accent bg-accent/10 border border-accent/20 px-2.5 py-1 rounded-full mb-4">
    {tag}
  </div>
  <h2 class="text-[22px] font-bold leading-tight text-text mb-2 group-hover:text-accent transition-colors">{title}</h2>
  <p class="text-muted text-[15px] leading-relaxed mb-4">{description}</p>
  <div class="flex items-center justify-between text-xs text-dim">
    <span>{dateLabel} &middot; {minutes} min read</span>
    <span class="text-accent font-semibold group-hover:translate-x-0.5 transition-transform">Read article &rarr;</span>
  </div>
</a>
