---
import { getCollection } from 'astro:content';
import TagBadge from './TagBadge.astro';
import { relatedMap } from '../lib/related';

interface Props {
  currentSlug: string;
}
const { currentSlug } = Astro.props;

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const slugs = relatedMap[currentSlug] ?? [];
const related = slugs
  .map((s) => allPosts.find((p) => p.id === s))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---
{related.length > 0 && (
  <section class="mt-24 pt-12 border-t border-border" aria-labelledby="read-next-heading">
    <div class="flex items-baseline justify-between mb-7">
      <h2 id="read-next-heading" class="text-[12px] font-bold uppercase tracking-[0.14em] text-muted">
        Read next
      </h2>
      <a href="/" class="text-[13px] text-muted hover:text-text no-underline hover:no-underline">All articles &rarr;</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      {related.map((post) => (
        <a
          href={`/${post.id}/`}
          class="block group bg-card border border-border rounded-2xl p-6 hover:-translate-y-1 hover:shadow-[0_14px_40px_-12px_rgba(15,15,15,0.18)] hover:border-black/[0.12] transition-all duration-300 ease-out no-underline hover:no-underline"
        >
          <div class="mb-3">
            <TagBadge tag={post.data.tag} size="sm" />
          </div>
          <h3 class="text-[18px] font-bold leading-snug tracking-tight text-text mb-2 group-hover:text-accent transition-colors">
            {post.data.title}
          </h3>
          <p class="text-muted text-[14px] leading-relaxed line-clamp-3">
            {post.data.description}
          </p>
        </a>
      ))}
    </div>
  </section>
)}
