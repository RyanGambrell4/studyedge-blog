---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  tag?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://getstudyedge.com/og-studyedge-2026.png',
  type = 'website',
  pubDate,
  updatedDate,
  tag,
} = Astro.props;

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/favicon.png" />

  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="StudyEdge AI" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@getstudyedge" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
  {tag && <meta property="article:section" content={tag} />}

  <meta name="robots" content="index, follow" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <slot name="head" />
</head>
<body class="bg-bg text-text font-sans antialiased">
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { line-height: 1.65; -webkit-text-size-adjust: 100%; }
  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* Article prose styles */
  .prose h1 {
    font-size: clamp(34px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 16px;
    color: #111111;
  }
  .prose h2 {
    font-size: 26px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.015em;
    margin-top: 40px;
    margin-bottom: 16px;
    color: #111111;
  }
  .prose h3 {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.35;
    margin-top: 28px;
    margin-bottom: 10px;
    color: #111111;
  }
  .prose p {
    font-size: 17px;
    color: #111111;
    margin-bottom: 18px;
  }
  .prose ul, .prose ol {
    font-size: 17px;
    margin-bottom: 18px;
    padding-left: 22px;
  }
  .prose ul li, .prose ol li {
    margin-bottom: 8px;
  }
  .prose strong { color: #111111; font-weight: 700; }
  .prose a { color: #3B61C4; text-decoration: underline; }
  .prose a:hover { color: #2d4fa3; }
  .prose blockquote {
    border-left: 4px solid #3B61C4;
    padding: 4px 0 4px 18px;
    margin: 22px 0;
    color: #6B6B6B;
    font-style: italic;
  }
</style>
